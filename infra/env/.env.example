# --- App ---
ENVIRONMENT=local
LOG_LEVEL=INFO

# --- LLM providers ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
VOYAGE_API_KEY=

# Model selection (per-agent overridable)
CLAUDE_MODEL_HIGH_ACCURACY=claude-opus-4-8
CLAUDE_MODEL_STANDARD=claude-sonnet-5

# Embeddings
EMBEDDING_PROVIDER=voyage
VOYAGE_EMBEDDING_MODEL=voyage-3-large
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=1024

# --- Postgres ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=fashion_analyst
POSTGRES_USER=fashion_analyst
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+asyncpg://fashion_analyst:change-me@localhost:5432/fashion_analyst

# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-too

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# --- Redis / Celery ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Trade data ---
UN_COMTRADE_API_KEY=

# --- Pattern mockups ---
IMAGEGEN_PROVIDER=openai
OPENAI_IMAGE_MODEL=gpt-image-1
PATTERN_DATA_DIR=data

# --- Verification / anti-hallucination ---
CONFIDENCE_THRESHOLD=0.6

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
